# ============================================================
# Agent Article Demo — Environment Configuration
# Copy this file to .env and replace the placeholder values.
# NEVER commit your real .env file!
# ============================================================

# --- Provider API Keys (at least one required) ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
HF_API_KEY=your_huggingface_api_key_here

# --- Provider Priority (comma-separated, tried in order) ---
# Available: groq, gemini, openrouter, huggingface
PROVIDER_PRIORITY=groq,gemini,openrouter,huggingface

# --- Default model per provider ---
# Groq models: groq/llama-3.3-70b-versatile, groq/llama-3.1-8b-instant
# Gemini models: gemini/gemini-2.5-flash, gemini/gemini-2.5-flash-lite, gemini/gemini-3.5-flash
# OpenRouter: openrouter/meta-llama/llama-3.3-70b-instruct, openrouter/google/gemini-2.5-flash
# HuggingFace: huggingface/mistralai/Mistral-7B-Instruct-v0.3
DEFAULT_MODEL=groq/llama-3.3-70b-versatile

# --- Optional: Web Search API (for research-capable agents) ---
SERPER_API_KEY=your_serper_api_key_here

# --- Server ---
PORT=8000
HOST=0.0.0.0
